// Consumer Jenkinsfile. Run Hawckeye AFTER deploying to a test env.
// Results go to your dashboard, Linear, and email.
@Library('hawckeye') _

pipeline {
  agent any
  stages {
    // ...your deploy stage here...
    stage('Hawckeye') {
      steps {
        hawckeye(
          environmentUrl: 'https://staging.my-app.com', // or apk: 'build/app-release.apk'
          scans: 'security,qa,friction',
          hawkeyeCredId: 'hawckeye-token'               // Secret text = Hawckeye API key
        )
      }
    }
  }
}
