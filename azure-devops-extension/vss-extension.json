{
  "manifestVersion": 1,
  "id": "hawkeye-pentest",
  "name": "Hawkeye Autonomous Pentest",
  "version": "1.0.0",
  "publisher": "your-publisher-id",
  "description": "Trigger a Hawkeye pentest against an authorized URL or APK and report findings on the PR. Non-blocking by default.",
  "categories": ["Azure Pipelines"],
  "tags": ["security", "pentest", "DAST", "code review"],
  "icons": { "default": "icon.png" },
  "targets": [{ "id": "Microsoft.VisualStudio.Services" }],
  "contributions": [
    {
      "id": "hawkeye-scan-task",
      "type": "ms.vss-distributed-task.task",
      "targets": ["ms.vss-distributed-task.tasks"],
      "properties": { "name": "task" }
    }
  ],
  "files": [{ "path": "task" }]
}
