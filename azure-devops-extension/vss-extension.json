{
  "manifestVersion": 1,
  "id": "hawckeye",
  "name": "Hawckeye",
  "version": "1.0.0",
  "publisher": "hawckeye",
  "description": "Autonomously tests an authorized URL or APK for security, QA, and product-friction issues and reports findings on the PR. Non-blocking by default.",
  "categories": ["Azure Pipelines"],
  "tags": ["security", "qa", "quality", "testing"],
  "icons": { "default": "icon.png" },
  "targets": [{ "id": "Microsoft.VisualStudio.Services" }],
  "contributions": [
    {
      "id": "hawkeye-scan-task",
      "type": "ms.vss-distributed-task.task",
      "targets": ["ms.vss-distributed-task.tasks"],
      "properties": { "name": "task" }
    }
  ],
  "files": [{ "path": "task" }]
}
